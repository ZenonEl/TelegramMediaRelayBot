<?xml version="1.0" encoding="utf-8"?>
<root>
    <!-- Состояние: Добавление контакта -->
    <data name="State.AddContact.Prompt.EnterLink" xml:space="preserve">
        <value>Укажите ссылку человека:</value>
        <!-- Старое имя: SpecifyContactLink -->
    </data>
    <data name="State.AddContact.Success" xml:space="preserve">
        <value>Теперь ожидайте, когда контакт также добавит вас в свой список.</value>
        <!-- Старое имя: WaitForContactConfirmation -->
    </data>
    <data name="State.AddContact.Notification" xml:space="preserve">
        <value>Пользователь {0} хочет добавить вас в свои контакты.</value>
        <!-- Старое имя: UserWantsToAddYou -->
    </data>
    <data name="State.AddContact.Confirm.Addition" xml:space="preserve">
        <value>Подтвердите добавление (в противном случае напишите /start): </value>
        <!-- Старое имя: ConfirmAdditionText -->
    </data>
    <data name="State.AddContact.Confirm.WorkWith" xml:space="preserve">
        <value>Будем работать с этим контактом? 
ID: {0} 
Имя: {1} ?</value>
        <!-- Старое имя: WillWorkWithContact -->
    </data>

    <!-- Состояние: Входящие приглашения -->
    <data name="State.InboundInvite.Confirm.Accept" xml:space="preserve">
        <value>Вы точно хотите принять запрос? (в противном случае введите команду /start)</value>
        <!-- Старое имя: WaitAcceptInboundInvite -->
    </data>
    <data name="State.InboundInvite.Confirm.Decline" xml:space="preserve">
        <value>Вы точно хотите отменить запрос? (в противном случае введите команду /start)</value>
        <!-- Старое имя: WaitDeclineInboundInvite -->
    </data>

    <!-- Состояние: Исходящие приглашения -->
    <data name="State.OutboundInvite.Confirm.Decline" xml:space="preserve">
        <value>Вы точно хотите отменить свой запрос к этому человеку?</value>
        <!-- Старое имя: DeclineOutBound -->
    </data>

    <!-- Состояние: Редактирование групп -->
    <data name="State.EditGroup.Prompt.EnterId" xml:space="preserve">
        <value>{0} 

Укажите айди группы для работы:</value>
        <!-- Старое имя: ContactGroupInfoText -->
    </data>
    <!-- Состояние: Редактирование групп контактов -->
    <data name="State.EditContactGroup.Prompt.EnterIds" xml:space="preserve">
        <value>Отправьте ID контакта(ов)</value>
        <!-- Старое имя: InputContactIDsText -->
    </data>
    <data name="State.EditContactGroup.Confirm.Add" xml:space="preserve">
        <value>Вы точно хотите добавить эти контакты в группу?</value>
        <!-- Старое имя: ConfirmAddContactsToGroupText -->
    </data>
    <data name="State.EditContactGroup.Confirm.Remove" xml:space="preserve">
        <value>Вы точно хотите удалить эти контакты из группы?</value>
        <!-- Старое имя: ConfirmDeleteContactsFromGroupText -->
    </data>
    
    <!-- Состояние: Удаление контакта -->
    <data name="State.RemoveContact.Prompt.EnterIds" xml:space="preserve">
        <value>Укажите ID контактов для удаления:</value>
        <!-- Старое имя: InputContactId -->
    </data>
    <data name="State.RemoveContact.Prompt.EnterIds.Generic" xml:space="preserve">
        <value>Пожалуйста, введите один или несколько ID контактов, разделенных пробелами.</value>
        <!-- Старое имя: PleaseEnterContactIDs -->
    </data>
    <data name="State.RemoveContact.Confirm.Removal" xml:space="preserve">
        <value>Вы уверены, что хотите удалить следующих пользователей из ваших контактов?</value>
        <!-- Старое имя: ConfirmRemovalMessage -->
    </data>
    <data name="State.RemoveContact.Success" xml:space="preserve">
        <value>Процесс удаления завершен.</value>
        <!-- Старое имя: RemovalProcessCompleted -->
    </data>

    <!-- Состояние: Мьют/Размьют -->
    <data name="State.Mute.Instruction" xml:space="preserve">
        <value>Чтобы замутить человека (вы не будете получать от него медиа) вам нужно указать либо его ID либо его ссылку</value>
        <!-- Старое имя: MuteUserInstructions -->
    </data>
    <data name="State.Mute.Prompt.EnterTime" xml:space="preserve">
        <value>Чтобы перевести секунды в другие единицы времени, используйте следующие соотношения: 

1 минута = 60 секунд, 1 час = 3600 секунд, 1 день = 86400 секунд. 

Введите время мута в секундах или дату в формате ГГГГ-ММ-ДД ЧЧ:ММ:СС:</value>
        <!-- Старое имя: MuteTimeInstructions -->
    </data>
    <data name="State.Mute.Confirm.Final" xml:space="preserve">
        <value>Проверьте своё решение и подтвердите его, если вы уверены, что это то, что вам нужно (в противном случае напишите /start)</value>
        <!-- Старое имя: ConfirmFinalDecision -->
    </data>
    <data name="State.Mute.Success" xml:space="preserve">
        <value>Мут установлен.</value>
        <!-- Старое имя: MuteSet -->
    </data>
    <data name="State.Mute.Info.WillBeUnmuted" xml:space="preserve">
        <value>Пользователь будет размучен в {0:yyyy-MM-dd HH:mm:ss} (через {1} секунд).</value>
        <!-- Старое имя: UserWillBeUnmuted -->
    </data>
    <data name="State.Mute.Info.WillBeUnmutedAt" xml:space="preserve">
        <value>Пользователь будет размучен в {0:yyyy-MM-dd HH:mm:ss}.</value>
        <!-- Старое имя: UserWillBeUnmutedAt -->
    </data>
    <data name="State.Mute.Info.Indefinite" xml:space="preserve">
        <value>Пользователь будет замучен бессрочно.</value>
        <!-- Старое имя: UserWillBeMutedIndefinitely -->
    </data>
    <data name="State.Unmute.Instruction" xml:space="preserve">
        <value>Чтобы размутить человека (вы снова будете получать от него медиа) вам нужно указать либо его ID либо его ссылку</value>
        <!-- Старое имя: UnmuteUserInstructions -->
    </data>
    <data name="State.Unmute.Confirm.IsMuted" xml:space="preserve">
        <value>Пользователь находится в муте до: {0} 
Вы действительно хотите его размутить? Если нет, то напишите /start</value>
        <!-- Старое имя: UserInMute -->
    </data>
    <data name="State.Unmute.Success" xml:space="preserve">
        <value>Пользователь размучен.</value>
        <!-- Старое имя: UserUnmuted -->
    </data>
    <data name="State.DefaultAction.AutoSendTimeChanged" xml:space="preserve">
        <value>Время отправки медиа изменено на </value>
        <!-- Старое имя: AutoSendTimeChangedMessage -->
    </data>
    <data name="State.DefaultAction.AutoSendTimeNotChanged" xml:space="preserve">
        <value>Время отправки медиа не изменено.</value>
        <!-- Старое имя: AutoSendTimeNotChangedMessage -->
    </data>
    <data name="State.DefaultAction.ActionChanged" xml:space="preserve">
        <value>Действие по умолчанию успешно изменено.</value>
        <!-- Старое имя: DefaultActionChangedMessage -->
    </data>
    <data name="State.DefaultAction.ActionNotChanged" xml:space="preserve">
        <value>Действие по умолчанию не изменено.</value>
        <!-- Старое имя: DefaultActionNotChangedMessage -->
    </data>
    <data name="State.DefaultAction.TimeoutMessage" xml:space="preserve">
        <value>⏳ Отправляю по умолчанию…</value>
        <!-- Старое имя: DefaultActionTimeoutMessage -->
    </data>
    <data name="State.CanceledByUser" xml:space="preserve">
        <value>❎ Отменено пользователем</value>
        <!-- Старое имя: CanceledByUserMessage -->
    </data>
    <data name="State.ContactLinks.ConfirmList" xml:space="preserve">
        <value>К обработке:\n{0}\n\nПодтвердить?</value>
    </data>
    <data name="State.CreateGroup.Prompt.EnterName" xml:space="preserve">
        <value>Придумайте название группы и отправьте его мне:</value>
        <!-- Старое имя: NewGroupText -->
    </data>
    <data name="State.EditGroup.Prompt.EnterId" xml:space="preserve">
        <value>Напиши мне айди группы для редактирования:</value>
        <!-- Старое имя: EditInputText -->
    </data>
    <data name="State.EditGroup.Prompt.EnterName" xml:space="preserve">
        <value>Напиши мне новое название группы:</value>
        <!-- Старое имя: NewGroupNameText -->
    </data>
    <data name="State.EditGroup.Prompt.EnterDescription" xml:space="preserve">
        <value>Напиши мне новое описание группы:</value>
        <!-- Старое имя: NewGroupDescriptionText -->
    </data>
    <data name="State.DeleteGroup.Prompt.EnterId" xml:space="preserve">
        <value>Напишите мне айди группы для удаления:</value>
        <!-- Старое имя: DeleteInputText -->
    </data>
    <data name="State.AddDomain.Prompt.EnterDomains" xml:space="preserve">
        <value>Введите домены которые хотите добавить</value>
        <!-- Старое имя: EnterDomainsToAddPrompt -->
    </data>
    <data name="State.RemoveDomain.Prompt.EnterDomains" xml:space="preserve">
        <value>Введите домены которые хотите удалить</value>
        <!-- Старое имя: EnterDomainsToRemovePrompt -->
    </data>
    <data name="State.UpdateLink.Confirm.KeepContacts" xml:space="preserve">
        <value>Вы уверены что хотите создать новую личную ссылку и сохранить при этом связи с текущими контактами?</value>
        <!-- Старое имя: UpdateLinkKeepContactsConfirmation -->
    </data>
    <data name="State.UpdateLink.Warning.NewContacts" xml:space="preserve">
        <value>Будьте аккуратны! Обратить действия невозможно! Все контакты будут удалены! Вы получите новую ссылку, по старой Вас найти уже не получится!
Вы уверены что хотите продолжить?</value>
        <!-- Старое имя: UpdateLinkNewContactsWarning -->
    </data>
    <data name="State.UpdateLink.Prompt.EnterIds" xml:space="preserve">
        <value>Введите айди ваших контактов</value>
        <!-- Старое имя: EnterContactIdsPrompt -->
    </data>
    <data name="State.Confirm.ProcessList" xml:space="preserve">
        <value>Указанные ID:

{0}

Продолжить?</value>
        <!-- Старое имя: ProcessIDsList -->
    </data>
    <data name="State.Success.ItemsProcessed" xml:space="preserve">
        <value>Успешно обработано: {0}</value>
        <!-- Старое имя: SuccessMessageProcessIDsList -->
    </data>
</root>