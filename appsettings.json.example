{
    "AppSettings": {
        "TelegramBotToken": "1234:abcd",
        "SqlConnectionString": "Server=IPAddress;Database=DatabaseName;User ID=UserName;Password=UserPassword;",
        "DatabaseName": "TelegramMediaRelayBot",
        "DatabaseType": "MySql",
        "Language": "en-US",
        "Proxy": "socks5://127.0.0.1:9050",
        "UserUnMuteCheckInterval": 20,
        "UseGalleryDl": true,
        "AccessDeniedMessageContact": "",
        "DownloaderSettings": {
            "ConfigFilePath": "./downloader-config.json",
            "AutoLearningEnabled": true,
            "MaxFrequentDomains": 20,
            "CacheTimeout": "00:30:00"
        }
    },
    "Downloading": {
        "TargetUploadLimitMb": 49,
        "ExternalDownloadMaxSizeMb": 120,
        "PreflightEnabled": true,
        "IfTooLarge": "Transcode",
        "TargetPartSizeMb": 32,
        "TranscodeProfile": {
            "MaxResolution": "480p",
            "VideoBitrateKbps": 1200,
            "AudioBitrateKbps": 96,
            "Preset": "veryfast"
        }
    },
    "TextCleanup": {
        "Enabled": true,
        "Rules": [
            {
                "Domains": ["www.pinterest.com", "pinterest.com", "pin.it", "www.pin.it"],
                "Pattern": "^(смотри\s+|взгляните\s+|look\s+at\s+this[:!\s]+)",
                "Replacement": ""
            }
        ]
    },
    "Tor": {
        "Enabled": true,
        "TorControlPassword": "Password",
        "TorSocksHost": "127.0.0.1",
        "TorSocksPort": 9050,
        "TorControlPort": 9051,
        "TorChangingChainInterval": 5
    },
    "MessageDelaySettings": {
        "VideoGetDelay": 1000,
        "ContactSendDelay": 1000
    },
    "ConsoleOutputSettings": {
        "LogLevel": "Information",
        "ShowVideoDownloadProgress": false,
      "ShowVideoUploadProgress": false,
      "EnableFileLogging": false,
      "FilePath": "logs/bot-.log",
      "FileSizeLimitBytes": 10485760,
      "RetainedFileCountLimit": 7
    },
    "AccessPolicy": {
        "Enabled": false,

        "NewUsersPolicy": {
            "Enabled": false,
            "ShowAccessDeniedMessage": false,

            "AllowNewUsers": true,
            "AllowRules": {
                "AllowAll": true,
                "WhitelistedReferrerIds": [],
                "BlacklistedReferrerIds": []
            }
        }
    },
    "Backup": {
        "Enabled": true,
        "Schedule": {
            "OnStart": true,
            "OnShutdown": true,
            "DailyTimes": ["12:00"],
            "TimeZone": "UTC",
            "InitialDelayMinutes": 5
        },
        "Storage": {
            "Path": "backups",
            "UseGzip": true,
            "Retention": { "MaxCount": 14, "MaxAgeDays": 30 }
        },
        "Encryption": { "Enabled": false, "PasswordEnvVar": "DB_BACKUP_PASSWORD" },
        "ProviderOverride": null,
        "MySql": { "Cli": { "DumpPath": "mysqldump", "ClientPath": "mysql", "ExtraArgs": "" } },
        "Sqlite": { "UseVacuumInto": true },
        "Restore": {
            "Enabled": false,
            "BackupFile": "",
            "RequireConfirmationFile": "restore.ok",
            "VerifyChecksum": true,
            "TimeoutMinutes": 5,
            "Mode": "Auto"
        }
    }
}
