# ===================================================================
# Глобальные Настройки
# Настройки, которые применяются ко всем загрузчикам, если не переопределены локально.
# ===================================================================
GlobalSettings:
    # Максимальное количество одновременных загрузок во всей системе.
    MaxConcurrentDownloads: 3
    # Таймаут по умолчанию для одного шага загрузки (например, для одного ретрая).
    DefaultTimeout: "00:01:00" # 10 минут
    DownloadProgressLogLevel: Verbose

# ===================================================================
# Настройки Прокси-серверов
# Список доступных прокси-серверов, на которые могут ссылаться политики.
# ===================================================================
Proxies:
    # --- Прокси для Tor ---
    # Это имя ("tor_proxy") используется в политиках ниже.
    -   Name: "tor_proxy"
        Enabled: true
        # Адрес SOCKS5-прокси, который предоставляет Tor Browser или Tor-сервис.
        Address: "socks5://127.0.0.1:9150"
        # (Задел на будущее) Настройки для управления Tor для смены IP-цепочки.
        # ControlPort: 9051
        # ControlPassword: "YourTorPassword"

    # --- Пример выключенного прокси ---
    # Можно держать в конфиге, но выключать при необходимости.
    -   Name: "socks5_test"
        Enabled: true
        Address: "socks5://192.168.0.17:9050"

# ===================================================================
# Политики Повторных Попыток (Ретраи)
# Описывают, как система должна реагировать на различные ошибки.
# Правила проверяются по порядку, применяется первое совпавшее.
# ===================================================================
RetryPolicies:
    # --- Политика для обхода блокировок IP (самая специфичная, поэтому первая) ---
    -   Name: "IPBlockBypass"
        # Список подстрок в тексте ошибки, которые активируют это правило.
        ErrorPatterns:
            - "Your IP address is blocked"
            - "HTTP Error 403: Forbidden"
            - "Access denied"
            - "Requested post not available" # Добавим ошибку от GalleryDl
        # Максимальное количество попыток (1 первая + 2 ретрая).
        MaxAttempts: 3
        # Задержка перед следующей попыткой.
        Delay: "00:01:00"
        # Действие, которое нужно предпринять перед следующей попыткой.
        # 'UseProxy' - попытаться использовать прокси.
        Action: UseProxy
        # Имя прокси из секции Proxies.
        ProxyName: "socks5_test"

    # --- Политика для временных сетевых проблем ---
    -   Name: "NetworkIssues"
        ErrorPatterns:
            - "Too Many Requests"
            - "HTTP Error 429"
            - "Download timed out"
        MaxAttempts: 3
        # Увеличенная задержка для "остывания".
        Delay: "00:00:30"
        # Просто повторяем попытку без смены прокси.
        Action: None

    # --- Политика по умолчанию (ставится последней) ---
    # Сработает, если ни одно из правил выше не подошло.
    -   Name: "DefaultRetry"
        # "*" означает "любая другая ошибка".
        ErrorPatterns: ["*"]
        MaxAttempts: 2
        Delay: "00:00:05"
        Action: UseProxy
        ProxyName: "socks5_test"

# ===================================================================
# Настройки обработки медиа
# ===================================================================
MediaProcessing:
    MaxConcurrentProcessings: 2
    Ffmpeg:
        ExecutablePath: "ffmpeg"
        OperationTimeout: "00:20:00"
        Preset: "veryfast"
        Crf: 26
    
    Splitter:
        Enabled: true
        # Порог: 200 MB. Если больше - режем.
        ThresholdBytes: 52428800 
        # ВАЖНО: Ставим 45 MB (47185920 байт). Это безопасно для Telegram API.
        ChunkSizeBytes: 47185920

TextCleanup:
    # Список Regex-паттернов для удаления "мусора" из подписей.
    # Будут применены в указанном порядке.
    Patterns:
        # Пример: Удаляет "Смотрите это видео от @username в TikTok!"
        - "Смотрите это видео от .* в TikTok!"
        - "Make Your Day"
        - "Take a look! 📌"
    # (Опционально) Путь к файлу с дополнительными паттернами.
    PatternsFile: "text_cleanup_patterns.txt"

# ===================================================================
# Определения Загрузчиков
# Список всех доступных "инструментов" (загрузчиков) в системе.
# Фабрика будет выбирать из них на основе приоритета и UrlMatching.
# ===================================================================
Downloaders:

    # --- Загрузчик YtDlp ---
    -   Name: "YtDlp"
        Enabled: true
        Priority: 100
        ExecutablePath: "yt-dlp"

        UrlMatching:
            Mode: "Any" # Или Patterns, как тебе удобно
            Patterns:
                - "vt\\.tiktok\\.com/"
                - "youtu\\.be/"
                - "youtube\\.com/"
            PatternsFile: "DownloaderPatterns/ytdlp.txt"

        ProxyPolicy:
            Default: "socks5_test"
            SiteSpecific: {}

        # --- НОВАЯ СЕКЦИЯ: Аутентификация ---
        Authentication:
            # Имя файла в папке Secrets (например, bin/Debug/net8.0/Secrets/yt_cookies.txt)
            CookieFile: "yt_cookies.txt"
            # Если нужно логиниться (обычно для yt-dlp лучше куки, но вдруг)
            # Username: "${YOUTUBE_USER}" 
            # Password: "${YOUTUBE_PASS}"

        # --- НОВАЯ СЕКЦИЯ: Пост-процессоры ---
        # Имя должно совпадать с FfmpegPostProcessor.Name ("FfmpegConverter")
        PostProcessors: 
            - "VideoSplitter"
            - "FfmpegConverter" 

        ArgumentList:
            - "{Url}"
            - "--output"
            - "{OutputPath}/video.%(ext)s"
            # Прокси (если выключен, эта строка и следующая {Proxy} удалятся)
            - "--proxy"
            - "{Proxy}"
            # Куки (если файла нет, эти строки удалятся)
            - "--cookies"
            - "{Auth:CookiePath}"
            - "-f"
            - "bv*[height<=1080][ext=mp4]+ba[ext=m4a]/b[ext=mp4] / bv*+ba/b"
            - "--merge-output-format"
            - "mp4"


    # --- Загрузчик GalleryDl ---
    -   Name: "GalleryDl"
        Enabled: true
        Priority: 90
        ExecutablePath: "gallery-dl"

        UrlMatching:
            Mode: "Any"
            Patterns:
                - "instagram\\.com/"
                - "pinterest\\.com/"

        ProxyPolicy:
            Default: "socks5_test"
            SiteSpecific: {}

        Authentication:
            # Для Инсты и Пинтереста часто нужны куки
            CookieFile: "gallery_cookies.txt"
            # Можно использовать логин/пароль через переменные окружения
            # Username: "${INSTAGRAM_USER}"
            # Password: "${INSTAGRAM_PASS}"

        PostProcessors: []

        ArgumentList:
            - "{Url}"
            - "-d"
            - "{OutputPath}"
            - "-D"
            - "{OutputPath}"
            - "--proxy"
            - "{Proxy}"
            - "--cookies"
            - "{Auth:CookiePath}"
            # Пример использования логина/пароля, если они заданы
            #- "--username"
            #- "{Auth:User}"
            #- "--password"
            #- "{Auth:Password}"