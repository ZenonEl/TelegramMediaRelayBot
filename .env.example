# One-time credentials for the local Bot API server:
# https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local VPN client the stack tunnels through (must listen on 0.0.0.0).
# host.docker.internal resolves to the docker host from inside containers.
VPN_PROXY_TYPE=SOCKS5
VPN_PROXY_HOST=host.docker.internal
VPN_PROXY_PORT=2080
