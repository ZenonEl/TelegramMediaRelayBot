# One-time credentials for the local Bot API server:
# https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local VPN/proxy client the stack tunnels through, on 127.0.0.1:<port>.
# The stack uses host networking, so containers reach it just like the host does
# (the compose file hard-codes 127.0.0.1 as the proxy host).
VPN_PROXY_TYPE=SOCKS5
VPN_PROXY_PORT=2080
